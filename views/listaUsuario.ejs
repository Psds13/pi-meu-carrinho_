<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerenciar Usuários - Admin Panel</title>
    <link rel="stylesheet" href="/listas.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body>
    <div class="list-container-premium">
        <header class="list-header-premium">
            <div class="list-title-group">
                <h1 class="gradient-text">Usuários do Sistema</h1>
                <p>Gerenciamento de acessos e permissões</p>
            </div>
            <a href="/admin" class="btn-back-premium">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </header>

        <ul class="item-list-premium">
            <% 
            // Como no arquivo original era estático, mas o usuário usa EJS, 
            // vou manter a lógica de carregar de uma variável 'usuarios' se existir, 
            // ou manter os exemplos se for apenas frontend.
            if (typeof usuarios !== 'undefined') { 
                usuarios.forEach(usuario => { %>
                <li class="item-premium">
                    <div class="item-content">
                        <span class="item-title"><%= usuario.nome %></span>
                        <div class="item-info">
                            <i class="bi bi-envelope-at"></i>
                            <span><%= usuario.email %></span>
                            <span class="price-pill" style="background: rgba(0, 210, 255, 0.1); color: var(--admin-secondary);">ID: #<%= usuario.id %></span>
                        </div>
                    </div>
                    <div class="item-actions">
                        <a href="/editarUsuario/<%= usuario.id %>" class="btn-action btn-edit">
                            <i class="bi bi-person-gear"></i> Editar
                        </a>
                        <form action="/deletarUsuario/<%= usuario.id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn-action btn-delete" onclick="return confirm('Excluir este usuário permanentemente?')">
                                <i class="bi bi-person-x"></i> Excluir
                            </button>
                        </form>
                    </div>
                </li>
            <% })} else { %>
                <!-- Exemplos estáticos se a variável não vier do backend -->
                <% const dummyUsers = [
                    {id: 1, nome: "João Pedro", email: "joao@exemplo.com"},
                    {id: 2, nome: "Felipe Mesquita", email: "felipe@exemplo.com"},
                    {id: 3, nome: "Giuseppe Ramos", email: "giuseppe@exemplo.com"},
                    {id: 4, nome: "Alex Santos", email: "alex@exemplo.com"},
                    {id: 5, nome: "Carla Monteiro", email: "carla@exemplo.com"}
                ];
                dummyUsers.forEach(usuario => { %>
                <li class="item-premium">
                    <div class="item-content">
                        <span class="item-title"><%= usuario.nome %></span>
                        <div class="item-info">
                            <i class="bi bi-envelope-at"></i>
                            <span><%= usuario.email %></span>
                            <span class="price-pill" style="background: rgba(0, 210, 255, 0.1); color: var(--admin-secondary);">ID: #<%= usuario.id %></span>
                        </div>
                    </div>
                    <div class="item-actions">
                        <a href="/editarUsuario/<%= usuario.id %>" class="btn-action btn-edit">
                            <i class="bi bi-person-gear"></i> Editar
                        </a>
                        <button class="btn-action btn-delete">
                            <i class="bi bi-person-x"></i> Excluir
                        </button>
                    </div>
                </li>
                <% }) %>
            <% } %>
        </ul>
    </div>
</body>
</html>
