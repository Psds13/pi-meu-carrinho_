<header id="main-header" class="header-premium">
    <div class="container header-container">
        <!-- Logo Section -->
        <div class="logo-section">
            <a href="/" class="logo-link">
                <img src="/image/logo.png" alt="Meu Carrinho" class="logo-img">
            </a>
        </div>
        
        <!-- Search Section -->
        <div class="search-section">
            <form action="/produtos" method="get" class="search-bar-modern">
                <div class="input-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" name="search" placeholder="O que você procura hoje?" class="search-input">
                    <button type="submit" class="btn btn-primary btn-search-premium">Buscar</button>
                </div>
            </form>
        </div>
        
        <!-- Mobile Toggle Button -->
        <button class="mobile-menu-toggle" aria-label="Abrir menu">
            <i class="bi bi-list"></i>
        </button>

        <!-- Actions Section -->
        <div class="actions-section">
            <nav class="main-nav">
                <a href="/#supermarkets-section" class="nav-item">Mercados</a>
                <a href="/listas/minhasListas" class="nav-item cart-btn">
                    <i class="bi bi-basket-fill"></i>
                    <span>Minhas Listas</span>
                </a>
            </nav>
            
            <div class="user-controls">
                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="user-greeting">
                        <img src="https://ui-avatars.com/api/?name=<%= user.nome %>&background=0077ff&color=fff" alt="User" class="avatar">
                        <div class="user-dropdown">
                            <span class="user-info">Olá, <%= user.nome.split(' ')[0] %></span>
                            <a href="/auth/logout" class="btn btn-primary btn-logout-premium">Sair</a>
                        </div>
                    </div>
                <% } else { %>
                    <div class="auth-flow">
                        <a href="/login" class="nav-item">Login</a>
                        <a href="/cadastro" class="btn btn-primary btn-join-premium">Criar Conta</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</header>