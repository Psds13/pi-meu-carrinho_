<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista Mateus - Admin Panel</title>
    <link rel="stylesheet" href="/listas.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body>
    <div class="list-container-premium">
        <header class="list-header-premium">
            <div class="list-title-group">
                <h1 class="gradient-text">Grupo Mateus</h1>
                <p>Gerenciamento de produtos em estoque</p>
            </div>
            <a href="/admin" class="btn-back-premium">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </header>

        <ul class="item-list-premium">
            <% produtos.forEach(produto => { %>
                <li class="item-premium">
                    <div class="item-content">
                        <span class="item-title"><%= produto.nome %></span>
                        <div class="item-info">
                            <span class="price-pill">R$ <%= produto.preco.toFixed(2) %></span>
                            <span>ID: #<%= produto.id %></span>
                        </div>
                    </div>
                    <div class="item-actions">
                        <a href="/editar/<%= produto.id %>" class="btn-action btn-edit">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>
                        <form action="/deletar/<%= produto.id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn-action btn-delete" onclick="return confirm('Tem certeza?')">
                                <i class="bi bi-trash3"></i> Excluir
                            </button>
                        </form>
                    </div>
                </li>
            <% }) %>
            <% if (produtos.length === 0) { %>
                <li class="item-premium" style="justify-content: center; color: var(--admin-text-muted);">
                    Nenhum produto encontrado neste mercado.
                </li>
            <% } %>
        </ul>
    </div>
</body>
</html>
