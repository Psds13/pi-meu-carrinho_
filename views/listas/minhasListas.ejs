<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minhas Listas - Meu Carrinho</title>
    <link rel="icon" type="image/png" href="/image/logo.png">
    <link rel="stylesheet" href="/main-responsive.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <!-- Cabeçalho -->
    <%- include('../partials/header') %>

    <main class="page-container container mb-5">
        <header class="section-header d-flex justify-content-between align-items-center mb-4">
            <div class="header-text">
                <h1 class="gradient-text">Minhas Listas</h1>
                <p class="text-secondary">Organize suas compras e economize</p>
            </div>
            <a href="/" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Início
            </a>
        </header>

        <div class="list-cards-wrapper">
            <!-- Exemplo de Lista Ativa -->
            <div class="list-item-card premium-shadow mb-3 p-4 bg-white rounded-3 d-flex justify-content-between align-items-center border-start border-primary border-4">
                <div class="list-details">
                    <h3 class="h5 mb-2 fw-bold">🛒 Compras do Mês - Abril</h3>
                    <div class="list-meta d-flex flex-wrap gap-3 small text-secondary">
                        <span class="badge bg-primary-soft text-primary p-2 px-3 rounded-pill fw-bold">Total: R$ 420,50</span>
                        <span><i class="bi bi-calendar3 me-1"></i> 29/03/2026</span>
                        <span class="text-success fw-bold"><i class="bi bi-graph-up-arrow me-1"></i> Economia: R$ 45,20</span>
                    </div>
                </div>
                <div class="list-actions d-flex gap-2">
                    <a href="#" class="btn btn-light-primary btn-icon" title="Ver detalhes">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a href="#" class="btn btn-light-danger btn-icon" title="Excluir">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>

            <!-- Exemplo de Lista por Mercado -->
            <div class="list-item-card premium-shadow mb-3 p-4 bg-white rounded-3 d-flex justify-content-between align-items-center border-start border-success border-4">
                <div class="list-details">
                    <h3 class="h5 mb-2 fw-bold">🍅 Churrasco de Domingo (Atacadão)</h3>
                    <div class="list-meta d-flex flex-wrap gap-3 small text-secondary">
                        <span class="badge bg-success-soft text-success p-2 px-3 rounded-pill fw-bold">Total: R$ 185,20</span>
                        <span><i class="bi bi-cart-check me-1"></i> 12 itens selecionados</span>
                    </div>
                </div>
                <div class="list-actions d-flex gap-2">
                    <a href="#" class="btn btn-light-primary btn-icon" title="Ver detalhes">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a href="#" class="btn btn-light-danger btn-icon" title="Excluir">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>

            <!-- Seção de Criar Nova Lista -->
            <section class="create-list-section mt-5 p-5 text-center bg-white rounded-4 premium-shadow border-dashed">
                <div class="icon-circle mx-auto mb-4 bg-primary-soft text-primary">
                    <i class="bi bi-plus-circle h1 m-0"></i>
                </div>
                <h3 class="fw-bold mb-2">Criar nova lista de compras</h3>
                <p class="text-secondary mb-4 mx-auto" style="max-width: 500px;">
                    Dê um nome para sua lista e comece a adicionar produtos de diferentes mercados para comparar e economizar.
                </p>
                <form action="/listas/criar" method="POST" class="d-flex flex-column flex-sm-row gap-3 justify-content-center max-width-600 mx-auto">
                    <input type="text" name="nome" placeholder="Ex: Mercado da Semana" required class="form-control form-control-lg">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Criar Lista</button>
                </form>
            </section>
        </div>
    </main>

    <!-- Rodapé -->
    <footer class="footer-premium mt-5">
        <div class="container footer-grid">
            <div class="footer-section footer-logo">
                <img src="/image/logo.png" alt="Logo Meu Carrinho">
                <p class="copyright">&copy; 2024 MeuCarrinho. Todos os direitos reservados</p>
            </div>
            
            <div class="footer-section footer-links">
                <h4>Navegação</h4>
                <ul>
                    <li><a href="/">Início</a></li>
                    <li><a href="/#supermarkets-section">Mercados</a></li>
                    <li><a href="/listas/minhas-listas">Minhas Listas</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Contatos</h4>
                <div class="social-links social-icons">
                    <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/mobile-menu.js"></script>
</body>
</html>

